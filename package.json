    "jsdom": "^27.2.0",
    "playwright": "^1.56.1",
    "react-test-renderer": "^19.2.0",
    "storybook": "10.0.8",
    "typescript": "5.9.2",
    "vite": "^7.2.2",
    "vitest": "^4.0.10",
    "vitest-browser-react": "^2.0.2"
