    "@playwright/test": "^1.56.1",
    "@react-router/dev": "^7.9.6",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "10.0.8",
    "@storybook/addon-docs": "10.0.8",
