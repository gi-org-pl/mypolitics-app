    "@react-router/serve": "^7.9.6",
    "@tailwindcss/vite": "^4.1.17",
    "axios": "^1.13.2",
    "isbot": "^5.1.32",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.6",
    "tailwind-merge": "^3.4.0",
